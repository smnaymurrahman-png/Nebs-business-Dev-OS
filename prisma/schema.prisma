generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Existing enums ───────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum ServiceType {
  WORDPRESS
  FULL_STACK
  UI_UX
  WEBFLOW
  SHOPIFY
  DIGITAL_MARKETING
  OTHER
}

enum ProposalStatus {
  PROPOSAL_SENT
  COMMUNICATION_RUNNING
  PAYMENT_PENDING
  PROPOSAL_REJECTED
  ORDER_COMPLETED
}

enum ProfileType {
  UI_UX
  WORDPRESS
  FULL_STACK
  DIGITAL_MARKETING
  WEBFLOW_SHOPIFY_FRAMER
  OTHER
}

enum AccountType {
  PAID
  FREE
}

enum SubscriptionType {
  MONTHLY
  YEARLY
}

enum LeadType {
  COLD
  HOT
  WARM
}

enum ConnectionType {
  BY_PHONE
  BY_EMAIL
  BY_WHATSAPP
}

// Expanded by migration 003 with 8 affiliate pipeline stages.
// Original values (INTERESTED…PENDING_DECISION) are unchanged.
enum LeadStatus {
  INTERESTED
  NOT_INTERESTED
  NO_RESPONSE
  FOLLOW_UP
  PENDING_DECISION
  SUBMITTED
  ACCEPTED
  QUOTATION_SENT
  NOT_RESPONDING
  MEETING_PENDING
  MEETING_DONE
  ONBOARDED
  REJECTED
}

enum AdPlatform {
  GOOGLE_ADS
  YOUTUBE_ADS
  BING_ADS
  OTHER_ADS
}

enum BudgetType {
  DAILY
  LIFETIME
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Affiliate OS enums (migrations 002–013) ──────────────────────────────────

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

// Spec's "lead_type" intent field — stored as lead_intent in DB to avoid
// collision with the existing lead_type column (COLD/HOT/WARM).
enum LeadIntent {
  NEED_QUOTATION
  INTERESTED
  URGENT
}

enum ProjectStatus {
  ONGOING
  COMPLETED
  CANCELLED
}

enum LeadSource {
  MANUAL
  PUBLIC_FORM
}

enum LeadActivityType {
  NOTE
  STATUS_CHANGE
  PROJECT_STATUS_CHANGE
}

enum MeetingLocationType {
  ONLINE
  OFFLINE
}

enum MeetingRequestStatus {
  REQUESTED
  APPROVED
  SCHEDULED
  CANCELLED
}

enum MeetingResult {
  NOT_INTERESTED
  QUOTATION_SENT
  ONBOARDED
  NEED_ANOTHER_MEETING
}

enum PayoutMethodType {
  BKASH
  NAGAD
  BANK
  INTERNATIONAL
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PAID
  REJECTED
}

enum CommissionStatus {
  PENDING
  AVAILABLE
  PAID
}

enum NotificationRecipientType {
  AFFILIATE
  ADMIN
}

// ─── Existing models ──────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  designation String?
  role        Role     @default(USER)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Named relations — User has two FKs on the leads table (createdById + acceptedBy)
  leads         Lead[]  @relation("LeadCreatedBy")
  acceptedLeads Lead[]  @relation("LeadAcceptedBy")

  clients             Client[]
  proposals           Proposal[]
  accounts            Account[]
  marketplaceProfiles MarketplaceProfile[]
  reports             Report[]
  meetings            Meeting[]
  meetingAssignments  MeetingAssignment[]

  // Affiliate OS
  approvedAffiliates Affiliate[]
  offers             Offer[]
  leadActivities     LeadActivity[]
  scheduledMeetings  AffiliateMeeting[]
  processedPayouts   Payout[]

  @@map("users")
}

model Client {
  id           String   @id @default(cuid())
  clientId     String   @unique
  name         String
  email        String
  phone        String
  country      String
  businessName String
  platform     String
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User       @relation(fields: [createdById], references: [id])
  proposals Proposal[]

  @@map("clients")
}

model Proposal {
  id              String         @id @default(cuid())
  clientId        String
  platform        String
  projectName     String
  projectDetails  String
  amount          Float
  proposal        String
  messageToClient String
  connectIn       Int
  costing         Float
  serviceType     ServiceType
  currentStatus   ProposalStatus @default(PROPOSAL_SENT)
  followUp        Int            @default(0)
  remark          String?
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  client Client @relation(fields: [clientId], references: [id])
  user   User   @relation(fields: [createdById], references: [id])

  @@map("proposals")
}

model Account {
  id               String           @id @default(cuid())
  platformName     String
  profileName      String
  emailAddress     String
  password         String
  phoneNumber      String
  specialQuestion  String?
  specialAnswer    String?
  profileType      ProfileType
  accountType      AccountType
  subscriptionType SubscriptionType
  amount           Float
  assignedPerson   String?
  assignedDevice   String?
  assignedIp       String?
  additionalDevice String?
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [createdById], references: [id])

  @@map("accounts")
}

model MarketplaceProfile {
  id              String      @id @default(cuid())
  platformName    String
  profileName     String
  emailAddress    String
  password        String
  phoneNumber     String
  specialQuestion String?
  specialAnswer   String?
  profileType     ProfileType
  isPaid          Boolean     @default(false)
  totalInvestment Float       @default(0)
  amount          Float
  assignedPerson  String?
  assignedDevice  String?
  assignedIp      String?
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user User @relation(fields: [createdById], references: [id])

  @@map("marketplace_profiles")
}

model Lead {
  id              String          @id @default(cuid())
  fullName        String
  emailAddress    String
  phoneNumber     String
  website         String?
  businessName    String
  businessDetails String
  leadType        LeadType
  leadFrom        String
  isPaid          Boolean         @default(false)
  connection      ConnectionType?
  leadStatus      LeadStatus      @default(INTERESTED)
  lastUpdate      String?
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Affiliate OS fields (migration 003 — snake_case columns in DB)
  industryId      String?       @map("industry_id")
  serviceTypeId   String?       @map("service_type_id")
  referenceAmount Decimal?      @map("reference_amount") @db.Decimal(12, 2)
  leadIntent      LeadIntent?   @map("lead_intent")
  projectStatus   ProjectStatus? @map("project_status")
  affiliateId     String?       @map("affiliate_id")
  source          LeadSource?
  dealValue       Decimal?      @map("deal_value") @db.Decimal(12, 2)
  acceptedBy      String?       @map("accepted_by")
  onboardedAt     DateTime?     @map("onboarded_at")

  // Named — User has two FKs on this table
  user           User   @relation("LeadCreatedBy", fields: [createdById], references: [id])
  acceptedByUser User?  @relation("LeadAcceptedBy", fields: [acceptedBy], references: [id])

  // Affiliate OS relations
  industry         Industry?          @relation(fields: [industryId], references: [id])
  serviceTypeOpt   ServiceTypeLookup? @relation(fields: [serviceTypeId], references: [id])
  affiliate        Affiliate?         @relation(fields: [affiliateId], references: [id])
  activities       LeadActivity[]
  affiliateMeetings AffiliateMeeting[]
  commission       Commission?

  @@map("leads")
}

model Report {
  id              String     @id @default(cuid())
  platform        AdPlatform
  landingPageLink String
  adsStartingDate DateTime
  budgetType      BudgetType
  budget          Float
  totalSpend      Float      @default(0)
  totalClicks     Int        @default(0)
  totalLeads      Int        @default(0)
  totalMeetings   Int        @default(0)
  createdById     String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user User @relation(fields: [createdById], references: [id])

  @@map("reports")
}

model Meeting {
  id            String        @id @default(cuid())
  meetingDate   DateTime
  meetingTopic  String
  priorityLevel PriorityLevel
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User                @relation(fields: [createdById], references: [id])
  assignees MeetingAssignment[]

  @@map("meetings")
}

model MeetingAssignment {
  id        String @id @default(cuid())
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_assignments")
}

// ─── Affiliate OS models (migrations 001–013) ─────────────────────────────────

// Admin-managed industry dropdown for the affiliate Add Lead form.
model Industry {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leads Lead[]

  @@map("industries")
}

// Admin-managed service type dropdown for the affiliate Add Lead form.
// Distinct from the ServiceType Postgres ENUM used by proposals.
// Model is named ServiceTypeLookup to avoid shadowing that enum.
model ServiceTypeLookup {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leads Lead[]

  @@map("service_types")
}

model Affiliate {
  id            String          @id @default(cuid())
  fullName      String          @map("full_name")
  email         String          @unique
  phone         String
  passwordHash  String          @map("password_hash")
  affiliateCode String          @unique @map("affiliate_code")
  status        AffiliateStatus @default(PENDING)
  approvedBy    String?         @map("approved_by")
  approvedAt    DateTime?       @map("approved_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  approver      User?                      @relation(fields: [approvedBy], references: [id])
  leads         Lead[]
  meetings      AffiliateMeeting[]
  attendances   AffiliateMeetingAttendee[]
  payoutMethods PayoutMethod[]
  payouts       Payout[]
  commissions   Commission[]

  @@map("affiliates")
}

// Immutable activity log per lead (notes + auto-logged status changes).
model LeadActivity {
  id         String          @id @default(cuid())
  leadId     String          @map("lead_id")
  type       LeadActivityType
  fromStatus String?         @map("from_status")
  toStatus   String?         @map("to_status")
  note       String?
  createdBy  String          @map("created_by")
  createdAt  DateTime        @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [createdBy], references: [id])

  @@map("lead_activity")
}

// People who can be added as attendees to affiliate meetings.
// They do not have a system login; they receive email invitations only.
model MeetingPerson {
  id        String   @id
  name      String
  email     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  meetingAttendances AffiliateMeetingAttendee[]

  @@map("meeting_persons")
}

// Affiliate-initiated meeting requests. Separate from the internal Meeting model.
model AffiliateMeeting {
  id              String               @id @default(cuid())
  leadId          String               @map("lead_id")
  affiliateId     String               @map("affiliate_id")
  topic           String
  scheduledAt     DateTime?            @map("scheduled_at")
  locationType    MeetingLocationType? @map("location_type")
  meetingLink     String?              @map("meeting_link")
  meetingLocation String?              @map("meeting_location")
  requestStatus   MeetingRequestStatus @default(REQUESTED) @map("request_status")
  result          MeetingResult?
  createdBy       String?              @map("created_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  lead      Lead      @relation(fields: [leadId], references: [id])
  affiliate Affiliate @relation(fields: [affiliateId], references: [id])
  scheduler User?     @relation(fields: [createdBy], references: [id])
  attendees AffiliateMeetingAttendee[]

  @@map("affiliate_meetings")
}

// Junction: each row is a MeetingPerson OR an Affiliate attendee (never both).
model AffiliateMeetingAttendee {
  id              String   @id @default(cuid())
  meetingId       String   @map("meeting_id")
  meetingPersonId String?  @map("meeting_person_id")
  affiliateId     String?  @map("affiliate_id")
  createdAt       DateTime @default(now()) @map("created_at")

  meeting       AffiliateMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingPerson MeetingPerson?   @relation(fields: [meetingPersonId], references: [id], onDelete: Cascade)
  affiliate     Affiliate?       @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("affiliate_meeting_attendees")
}

// Admin-published service packages; affiliates view these read-only.
model Offer {
  id          String   @id @default(cuid())
  serviceName String   @map("service_name")
  details     String
  price       Decimal  @db.Decimal(12, 2)
  duration    String
  authorId    String   @map("author_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id])

  @@map("offers")
}

model PayoutMethod {
  id          String          @id @default(cuid())
  affiliateId String          @map("affiliate_id")
  type        PayoutMethodType
  details     Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  payouts   Payout[]

  @@map("payout_methods")
}

model Payout {
  id             String       @id @default(cuid())
  affiliateId    String       @map("affiliate_id")
  payoutMethodId String       @map("payout_method_id")
  amount         Decimal      @db.Decimal(12, 2)
  status         PayoutStatus @default(REQUESTED)
  rejectReason   String?      @map("reject_reason")
  processedBy    String?      @map("processed_by")
  paidAt         DateTime?    @map("paid_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  affiliate    Affiliate    @relation(fields: [affiliateId], references: [id])
  payoutMethod PayoutMethod @relation(fields: [payoutMethodId], references: [id])
  processor    User?        @relation(fields: [processedBy], references: [id])
  commissions  Commission[]

  @@map("payouts")
}

// One record per onboarded lead. Tracks the 25-day hold and release cycle.
model Commission {
  id          String           @id @default(cuid())
  leadId      String           @unique @map("lead_id")
  affiliateId String           @map("affiliate_id")
  dealValue   Decimal          @map("deal_value") @db.Decimal(12, 2)
  rate        Decimal          @default(0.15) @db.Decimal(5, 4)
  amount      Decimal          @db.Decimal(12, 2)
  status      CommissionStatus @default(PENDING)
  onboardedAt DateTime         @map("onboarded_at")
  releaseDate DateTime         @map("release_date")
  payoutId    String?          @map("payout_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  lead      Lead      @relation(fields: [leadId], references: [id])
  affiliate Affiliate @relation(fields: [affiliateId], references: [id])
  payout    Payout?   @relation(fields: [payoutId], references: [id])

  @@map("commissions")
}

// Polymorphic notification inbox: recipient is either an Affiliate or a User.
// No FK on recipient_id — enforced by the application layer.
model Notification {
  id            String                    @id @default(cuid())
  recipientType NotificationRecipientType @map("recipient_type")
  recipientId   String                    @map("recipient_id")
  type          String
  payload       Json                      @default("{}")
  readAt        DateTime?                 @map("read_at")
  createdAt     DateTime                  @default(now()) @map("created_at")

  @@map("notifications")
}
